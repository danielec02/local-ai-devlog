# Chiavi, segreti e config
.env
.env.*
!.env.example
*.api_key

# File di sistema Mac
.DS_Store
._*
.AppleDouble
.LSOverride

# Log di OpenClaw
openclaw/logs/
logs/*.log

# Ignora il file json con le password ma non l'esempio
configs/openclaw-stack/openclaw-data/openclaw.json
